<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
            <TableColumn fx:id="colName" prefWidth="300.0" text="Name" />
            <TableColumn fx:id="colStar" prefWidth="100.0" text="Base Star" />
        </columns>
    </TableView>

    <HBox spacing="10.0">
        <TextField fx:id="txtName" promptText="Character Name" />
        <ChoiceBox fx:id="cbStar" prefWidth="120.0" />
        <Button onAction="#addUma" text="Add" />
        <Button onAction="#updateUma" text="Update Selected" />
        <Button onAction="#deleteUma" text="Delete Selected" />
        <Button onAction="#clearFields" text="Clear" />
    </HBox>
</VBox>
